---
import StatusBadge from "@/components/StatusBadge.astro";
---

<section class="console-panel overflow-hidden">
  <div class="flex items-center justify-between border-b border-border/90 bg-bg/80 px-4 py-2">
    <div class="flex items-center gap-2">
      <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-yellow-300/80"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-green/80"></span>
    </div>
    <div class="hidden sm:flex items-center gap-2">
      <StatusBadge label="ONLINE" tone="green" />
      <StatusBadge label="AI SYSTEMS" tone="cyan" />
    </div>
  </div>
  <div class="p-5 sm:p-8">
    <slot />
  </div>
</section>
