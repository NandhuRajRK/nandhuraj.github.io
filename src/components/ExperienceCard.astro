---
import type { Experience } from "@/data/experience";

const { item } = Astro.props as { item: Experience };
---

<article class="rounded-lg border border-border bg-panel/60 p-5">
  <div class="flex flex-wrap items-center justify-between gap-2">
    <h3 class="text-lg font-semibold">{item.org}</h3>
    <span class="font-mono text-xs uppercase tracking-wider text-muted">{item.period}</span>
  </div>
  <p class="mt-2 font-medium text-accent">{item.role}</p>
  <p class="mt-3 text-sm leading-relaxed text-muted">{item.summary}</p>
</article>
